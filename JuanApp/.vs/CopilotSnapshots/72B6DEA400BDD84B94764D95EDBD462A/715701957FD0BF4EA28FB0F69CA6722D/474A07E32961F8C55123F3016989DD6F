@model JuanApp.Models.Product

<div class="modal-content">
    <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal">
            &times;
        </button>
    </div>
    <div class="modal-body">
        <!-- product details inner start -->
        <div class="product-details-inner">
            <div class="row">
                <div class="col-lg-5">
                    <div class="product-large-slider mb-20">
                        @if (Model.ProductImages != null && Model.ProductImages.Any())
                        {
                            @foreach (var image in Model.ProductImages)
                            {
                                <div class="pro-large-img img-zoom">
                                    <img src="~/assets/img/product/@image.ImageUrl"
                                         alt="product image" />
                                </div>
                            }
                        }
                        else
                        {
                            <div class="pro-large-img img-zoom">
                                <img src="~/assets/img/product/@Model.MainImageUrl"
                                     alt="product image" />
                            </div>
                        }
                    </div>
                    <div class="pro-nav">
                        @if (Model.ProductImages != null && Model.ProductImages.Any())
                        {
                            @foreach (var image in Model.ProductImages)
                            {
                                <div class="pro-nav-thumb">
                                    <img src="~/assets/img/product/@image.ImageUrl"
                                         alt="product thumb" />
                                </div>
                            }
                        }
                        else
                        {
                            <div class="pro-nav-thumb">
                                <img src="~/assets/img/product/@Model.MainImageUrl"
                                     alt="product thumb" />
                            </div>
                        }
                    </div>
                </div>
                <div class="col-lg-7">
                    <div class="product-details-des">
                        <h3 class="pro-det-title">@Model.Name</h3>
                        <div class="pro-review">
                            <span><a href="#">1 Review(s)</a></span>
                        </div>
                        <div class="price-box">
                            <span class="regular-price">$@(Model.Price - ((Model.Price * Model.DiscountPercentage) / 100))</span>
                            <span class="old-price"><del>$@Model.Price</del></span>
                        </div>
                        <p>
                            @Model.Description
                        </p>
                        <div class="quantity-cart-box d-flex align-items-center mb-20">
                            <div class="quantity">
                                <div class="pro-qty">
                                    <span class="dec qtybtn">-</span>
                                    <input type="text" class="qty-input" value="1" />
                                    <span class="inc qtybtn">+</span>
                                </div>
                            </div>
                            <a href="cart.html" class="btn btn-default">Add To Cart</a>
                        </div>
                        <div class="availability mb-20">
                            <h5 class="cat-title">Availability:</h5>
                            <span>In Stock</span>
                        </div>
                        <div class="share-icon">
                            <h5 class="cat-title">Share:</h5>
                            <a href="#"><i class="fa fa-facebook"></i></a>
                            <a href="#"><i class="fa fa-twitter"></i></a>
                            <a href="#"><i class="fa fa-pinterest"></i></a>
                            <a href="#"><i class="fa fa-google-plus"></i></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- product details inner end -->
    </div>
</div>