@model JuanApp.Models.Blog

@{
    ViewData["Title"] = "Delete Blog";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-8">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="card-title mb-0">Delete Blog</h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <strong>Warning!</strong> Are you sure you want to delete this blog? This action cannot be undone.
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Title:</strong></label>
                        <p>@Model.Title</p>
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Author:</strong></label>
                        <p>@Model.Author</p>
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Published Date:</strong></label>
                        <p>@Model.PublishedDate.ToString("MMMM dd, yyyy")</p>
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Content Preview:</strong></label>
                        <div class="border p-3 bg-light" style="max-height: 200px; overflow-y: auto;">
                            @Html.Raw(Model.Content)
                        </div>
                    </div>

                    <form asp-area="Manage" asp-controller="Blog" asp-action="Delete" method="post" style="display:inline;">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn btn-danger">Confirm Delete</button>
                    </form>
                    <a asp-area="Manage" asp-controller="Blog" asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </div>
        </div>
    </div>
</div>
