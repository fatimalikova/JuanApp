@model List<JuanApp.Models.Blog>

@{
    ViewData["Title"] = "Manage Blogs";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h4 class="card-title">Blogs</h4>
                    <a asp-area="Manage" asp-controller="Blog" asp-action="Create" class="btn btn-primary btn-sm">Add New Blog</a>
                </div>
                <div class="card-body">
                    @if (Model != null && Model.Count > 0)
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Title</th>
                                        <th>Author</th>
                                        <th>Published Date</th>
                                        <th>Image</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var blog in Model)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@blog.Title</strong>
                                            </td>
                                            <td>@blog.Author</td>
                                            <td>@blog.PublishedDate.ToString("MMMM dd, yyyy")</td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(blog.MainImageUrl))
                                                {
                                                    <img src="~/assets/img/blog/@blog.MainImageUrl" alt="@blog.Title" style="max-width: 50px; max-height: 50px;" />
                                                }
                                                else
                                                {
                                                    <span class="text-muted">No Image</span>
                                                }
                                            </td>
                                            <td>
                                                <button type="button" class="btn btn-sm btn-secondary" data-bs-toggle="modal" data-bs-target="#detailModal" 
                                                        data-id="@blog.Id" data-title="@blog.Title" data-author="@blog.Author" 
                                                        data-date="@blog.PublishedDate.ToString("MMMM dd, yyyy")" data-image="@blog.MainImageUrl"
                                                        data-content="@Html.Raw(System.Net.WebUtility.HtmlEncode(blog.Content))">
                                                    Detail
                                                </button>
                                                <button type="button" class="btn btn-sm btn-info" data-bs-toggle="modal" data-bs-target="#editModal"
                                                        data-id="@blog.Id" data-title="@blog.Title" data-author="@blog.Author" 
                                                        data-image="@blog.MainImageUrl" data-content="@Html.Raw(System.Net.WebUtility.HtmlEncode(blog.Content))">
                                                    Edit
                                                </button>
                                                <button type="button" class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#deleteModal"
                                                        data-id="@blog.Id" data-title="@blog.Title" data-author="@blog.Author"
                                                        data-date="@blog.PublishedDate.ToString("MMMM dd, yyyy")" data-image="@blog.MainImageUrl"
                                                        data-content="@Html.Raw(System.Net.WebUtility.HtmlEncode(blog.Content))">
                                                    Delete
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            No blogs found. <a asp-area="Manage" asp-controller="Blog" asp-action="Create">Create your first blog</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Detail Modal -->
<div class="modal fade" id="detailModal" tabindex="-1" aria-labelledby="detailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="detailModalLabel">Blog Detail</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="blogImage" class="mb-3"></div>
                <div class="mb-3">
                    <label class="form-label"><strong>Title:</strong></label>
                    <p id="blogTitle"></p>
                </div>
                <div class="mb-3">
                    <label class="form-label"><strong>Author:</strong></label>
                    <p id="blogAuthor"></p>
                </div>
                <div class="mb-3">
                    <label class="form-label"><strong>Published Date:</strong></label>
                    <p id="blogDate"></p>
                </div>
                <div class="mb-3">
                    <label class="form-label"><strong>Content:</strong></label>
                    <div class="border p-3 bg-light" id="blogContent" style="max-height: 300px; overflow-y: auto;"></div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editModalLabel">Edit Blog</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="editForm" method="post">
                <div class="modal-body">
                    <input type="hidden" id="editId" name="Id" />
                    <div class="mb-3">
                        <label for="editTitle" class="form-label">Title</label>
                        <input type="text" class="form-control" id="editTitle" name="Title" required />
                    </div>
                    <div class="mb-3">
                        <label for="editAuthor" class="form-label">Author</label>
                        <input type="text" class="form-control" id="editAuthor" name="Author" required />
                    </div>
                    <div class="mb-3">
                        <label for="editMainImageUrl" class="form-label">Main Image URL</label>
                        <input type="text" class="form-control" id="editMainImageUrl" name="MainImageUrl" />
                        <div id="currentImage" class="mt-2"></div>
                    </div>
                    <div class="mb-3">
                        <label for="editContent" class="form-label">Content</label>
                        <textarea class="form-control" id="editContent" name="Content" rows="8" required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Update Blog</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-danger">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel">Delete Blog</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-warning">
                    <strong>Warning!</strong> Are you sure you want to delete this blog? This action cannot be undone.
                </div>
                <div class="mb-3">
                    <label class="form-label"><strong>Title:</strong></label>
                    <p id="deleteTitle"></p>
                </div>
                <div class="mb-3">
                    <label class="form-label"><strong>Author:</strong></label>
                    <p id="deleteAuthor"></p>
                </div>
                <div class="mb-3">
                    <label class="form-label"><strong>Published Date:</strong></label>
                    <p id="deleteDate"></p>
                </div>
                <div class="mb-3">
                    <label class="form-label"><strong>Content Preview:</strong></label>
                    <div class="border p-3 bg-light" id="deleteContent" style="max-height: 200px; overflow-y: auto;"></div>
                </div>
            </div>
            <div class="modal-footer">
                <form id="deleteForm" method="post" style="display: inline;">
                    <input type="hidden" id="deleteId" name="Id" />
                    <button type="submit" class="btn btn-danger">Confirm Delete</button>
                </form>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Detail Modal
        const detailModal = document.getElementById('detailModal');
        detailModal.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            const blogId = button.getAttribute('data-id');
            const blogTitle = button.getAttribute('data-title');
            const blogAuthor = button.getAttribute('data-author');
            const blogDate = button.getAttribute('data-date');
            const blogImage = button.getAttribute('data-image');
            const blogContent = button.getAttribute('data-content');

            document.getElementById('blogTitle').textContent = blogTitle;
            document.getElementById('blogAuthor').textContent = blogAuthor;
            document.getElementById('blogDate').textContent = blogDate;
            document.getElementById('blogContent').innerHTML = decodeURIComponent(blogContent).replace(/&lt;/g, '<').replace(/&gt;/g, '>').replace(/&quot;/g, '"').replace(/&#39;/g, "'");

            const imageDiv = document.getElementById('blogImage');
            if (blogImage && blogImage.trim() !== '') {
                imageDiv.innerHTML = `<img src="/assets/img/blog/${blogImage}" alt="${blogTitle}" style="max-width: 100%; height: auto;" />`;
            } else {
                imageDiv.innerHTML = '<span class="text-muted">No Image</span>';
            }
        });

        // Edit Modal
        const editModal = document.getElementById('editModal');
        editModal.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            const blogId = button.getAttribute('data-id');
            const blogTitle = button.getAttribute('data-title');
            const blogAuthor = button.getAttribute('data-author');
            const blogImage = button.getAttribute('data-image');
            const blogContent = button.getAttribute('data-content');

            document.getElementById('editId').value = blogId;
            document.getElementById('editTitle').value = blogTitle;
            document.getElementById('editAuthor').value = blogAuthor;
            document.getElementById('editMainImageUrl').value = blogImage;
            document.getElementById('editContent').value = decodeURIComponent(blogContent).replace(/&lt;/g, '<').replace(/&gt;/g, '>').replace(/&quot;/g, '"').replace(/&#39;/g, "'");

            const imageDiv = document.getElementById('currentImage');
            if (blogImage && blogImage.trim() !== '') {
                imageDiv.innerHTML = `<img src="/assets/img/blog/${blogImage}" alt="${blogTitle}" style="max-width: 150px; height: auto;" />`;
            } else {
                imageDiv.innerHTML = '';
            }

            document.getElementById('editForm').action = `/Manage/Blog/Edit/${blogId}`;
        });

        // Delete Modal
        const deleteModal = document.getElementById('deleteModal');
        deleteModal.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            const blogId = button.getAttribute('data-id');
            const blogTitle = button.getAttribute('data-title');
            const blogAuthor = button.getAttribute('data-author');
            const blogDate = button.getAttribute('data-date');
            const blogContent = button.getAttribute('data-content');

            document.getElementById('deleteId').value = blogId;
            document.getElementById('deleteTitle').textContent = blogTitle;
            document.getElementById('deleteAuthor').textContent = blogAuthor;
            document.getElementById('deleteDate').textContent = blogDate;
            document.getElementById('deleteContent').innerHTML = decodeURIComponent(blogContent).replace(/&lt;/g, '<').replace(/&gt;/g, '>').replace(/&quot;/g, '"').replace(/&#39;/g, "'");

            document.getElementById('deleteForm').action = `/Manage/Blog/Delete/${blogId}`;
        });
    </script>
}


