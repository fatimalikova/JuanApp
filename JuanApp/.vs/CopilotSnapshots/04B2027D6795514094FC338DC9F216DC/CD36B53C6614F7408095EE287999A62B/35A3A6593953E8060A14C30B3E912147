@model List<JuanApp.Models.ProductImage>

@{
    ViewData["Title"] = "Manage Product Images";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h4 class="card-title">
                        Product Images - <strong>@ViewBag.ProductName</strong>
                    </h4>
                    <div>
                        <button class="btn btn-primary btn-sm" id="addImageBtn">Add Image</button>
                        <a asp-area="Manage" asp-controller="Product" asp-action="Index" class="btn btn-secondary btn-sm">Back</a>
                    </div>
                </div>
                <div class="card-body">
                    @if (Model != null && Model.Count > 0)
                    {
                        <div class="row" id="imageGallery">
                            @foreach (var image in Model)
                            {
                                <div class="col-md-3 mb-4 image-card" data-image-id="@image.Id">
                                    <div class="card">
                                        <img src="~/assets/img/product/@image.ImageUrl" alt="Product Image" class="card-img-top" style="height: 200px; object-fit: cover;">
                                        <div class="card-body">
                                            <p class="card-text small">@image.ImageUrl</p>
                                            <button type="button" class="btn btn-danger btn-sm btn-block delete-image-btn" data-image-id="@image.Id">Delete</button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            No images found. Click "Add Image" to upload product images.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Image Modal -->
<div class="modal fade" id="addImageModal" tabindex="-1" aria-labelledby="addImageModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addImageModalLabel">Add Product Image</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="addImageForm">
                    <div class="mb-3">
                        <label for="imageFile" class="form-label">Choose Image</label>
                        <input type="file" class="form-control" id="imageFile" accept="image/*" required />
                        <small class="text-muted">PNG, JPG, GIF up to 2MB</small>
                    </div>
                    <div id="imagePreview" style="display: none; margin-top: 15px; text-align: center;">
                        <p class="mb-2"><strong>Preview:</strong></p>
                        <img id="previewImg" style="max-width: 100%; max-height: 250px; border-radius: 5px;" />
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveImageBtn">Add Image</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const productId = '@ViewBag.ProductId';
        let addImageModal = null;

        // Initialize
        document.addEventListener('DOMContentLoaded', function() {
            addImageModal = new bootstrap.Modal(document.getElementById('addImageModal'));
            setupEventListeners();
        });

        function setupEventListeners() {
            // Add Image Button Click
            document.getElementById('addImageBtn').addEventListener('click', function() {
                document.getElementById('imageFile').value = '';
                document.getElementById('imagePreview').style.display = 'none';
                addImageModal.show();
            });

            // Image file preview
            document.getElementById('imageFile').addEventListener('change', function(e) {
                const file = e.target.files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = function(event) {
                        document.getElementById('previewImg').src = event.target.result;
                        document.getElementById('imagePreview').style.display = 'block';
                    };
                    reader.readAsDataURL(file);
                }
            });

            // Save Image Button Click
            document.getElementById('saveImageBtn').addEventListener('click', saveImage);

            // Cancel button using modal hidden event
            const modalElement = document.getElementById('addImageModal');
            modalElement.addEventListener('hidden.bs.modal', function() {
                document.getElementById('imageFile').value = '';
                document.getElementById('imagePreview').style.display = 'none';
            });

            // Use event delegation for delete buttons
            document.getElementById('imageGallery').addEventListener('click', function(e) {
                if (e.target.classList.contains('delete-image-btn')) {
                    deleteImage(e.target);
                }
            });
        }

        function saveImage() {
            const imageFile = document.getElementById('imageFile').files[0];

            if (!imageFile) {
                alert('Please select an image file');
                return;
            }

            const formData = new FormData();
            formData.append('productId', productId);
            formData.append('imageFile', imageFile);

            // Disable button to prevent duplicate submissions
            document.getElementById('saveImageBtn').disabled = true;

            fetch('/Manage/Product/AddImage', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                document.getElementById('saveImageBtn').disabled = false;

                if (data.success) {
                    // Add new image card to gallery
                    const gallery = document.getElementById('imageGallery');
                    if (!gallery) {
                        location.reload();
                        return;
                    }

                    // Remove "No images" message if it exists
                    const cardBody = gallery.closest('.card-body');
                    if (cardBody) {
                        const noImagesAlert = cardBody.querySelector('.alert-info');
                        if (noImagesAlert) {
                            noImagesAlert.remove();
                        }
                    }

                    const imageCard = document.createElement('div');
                    imageCard.className = 'col-md-3 mb-4 image-card';
                    imageCard.setAttribute('data-image-id', data.id);
                    imageCard.innerHTML = `
                        <div class="card">
                            <img src="/assets/img/product/${data.imageUrl}" alt="Product Image" class="card-img-top" style="height: 200px; object-fit: cover;">
                            <div class="card-body">
                                <p class="card-text small">${data.imageUrl}</p>
                                <button type="button" class="btn btn-danger btn-sm delete-image-btn" data-image-id="${data.id}">Delete</button>
                            </div>
                        </div>
                    `;
                    gallery.appendChild(imageCard);

                    // Close modal
                    addImageModal.hide();

                    // Clear form
                    document.getElementById('imageFile').value = '';
                    document.getElementById('imagePreview').style.display = 'none';
                } else {
                    alert(data.message || 'Error adding image');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Error adding image');
                document.getElementById('saveImageBtn').disabled = false;
            });
        }

        function deleteImage(button) {
            if (!confirm('Are you sure you want to delete this image?')) {
                return;
            }

            const imageId = button.getAttribute('data-image-id');
            const imageCard = document.querySelector(`[data-image-id="${imageId}"]`);

            const formData = new FormData();
            formData.append('imageId', imageId);

            // Disable button to prevent duplicate submissions
            button.disabled = true;

            fetch('/Manage/Product/DeleteImage', {
                method: 'POST',
                body: formData
            })
            .then(response => {
                if (response.ok) {
                    // Remove the image card with animation
                    imageCard.style.opacity = '0';
                    imageCard.style.transition = 'opacity 0.3s ease';
                    setTimeout(() => {
                        imageCard.remove();

                        // Show empty message if no images left
                        const gallery = document.getElementById('imageGallery');
                        if (gallery && gallery.children.length === 0) {
                            gallery.innerHTML = '<div class="alert alert-info">No images found. Click "Add Image" to upload product images.</div>';
                        }
                    }, 300);
                } else {
                    button.disabled = false;
                    alert('Error deleting image');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Error deleting image');
                button.disabled = false;
            });
        }
    </script>
}
