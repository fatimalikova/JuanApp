@model List<JuanApp.Models.ProductImage>

@{
    ViewData["Title"] = "Manage Product Images";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h4 class="card-title">
                        Product Images - <strong>@ViewBag.ProductName</strong>
                    </h4>
                    <div>
                        <button class="btn btn-primary btn-sm" id="addImageBtn">Add Image</button>
                        <a asp-area="Manage" asp-controller="Product" asp-action="Index" class="btn btn-secondary btn-sm">Back</a>
                    </div>
                </div>
                <div class="card-body">
                    @if (Model != null && Model.Count > 0)
                    {
                        <div class="row" id="imageGallery">
                            @foreach (var image in Model)
                            {
                                <div class="col-md-3 mb-4 image-card" data-image-id="@image.Id">
                                    <div class="card">
                                        <img src="~/assets/img/products/@image.ImageUrl" alt="Product Image" class="card-img-top" style="height: 200px; object-fit: cover;">
                                        <div class="card-body">
                                            <p class="card-text small">@image.ImageUrl</p>
                                            <button type="button" class="btn btn-danger btn-sm btn-block delete-image-btn" data-image-id="@image.Id">Delete</button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            No images found. Click "Add Image" to upload product images.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Image Modal -->
<div class="modal fade" id="addImageModal" tabindex="-1" aria-labelledby="addImageModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addImageModalLabel">Add Product Image</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="addImageForm">
                    <div class="mb-3">
                        <label for="imageUrl" class="form-label">Image URL</label>
                        <input type="text" class="form-control" id="imageUrl" placeholder="e.g., product-image-1.jpg" required />
                        <small class="text-muted">Enter the image filename from ~/assets/img/product/ folder</small>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveImageBtn">Add Image</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const productId = '@ViewBag.ProductId';

        // Add Image Button Click
        document.getElementById('addImageBtn').addEventListener('click', function() {
            document.getElementById('imageUrl').value = '';
            const addImageModal = new bootstrap.Modal(document.getElementById('addImageModal'));
            addImageModal.show();
        });

        // Save Image Button Click
        document.getElementById('saveImageBtn').addEventListener('click', function() {
            const imageUrl = document.getElementById('imageUrl').value;

            if (!imageUrl) {
                alert('Please enter an image URL');
                return;
            }

            const formData = new FormData();
            formData.append('productId', productId);
            formData.append('imageUrl', imageUrl);

            fetch('/Manage/Product/AddImage', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                // Add new image card to gallery
                const gallery = document.getElementById('imageGallery');
                if (!gallery.querySelector('.image-card')) {
                    gallery.innerHTML = '';
                }

                const imageCard = document.createElement('div');
                imageCard.className = 'col-md-3 mb-4 image-card';
                imageCard.setAttribute('data-image-id', data.id);
                imageCard.innerHTML = `
                    <div class="card">
                        <img src="/assets/img/products/${data.imageUrl}" alt="Product Image" class="card-img-top" style="height: 200px; object-fit: cover;">
                        <div class="card-body">
                            <p class="card-text small">${data.imageUrl}</p>
                            <button type="button" class="btn btn-danger btn-sm delete-image-btn" data-image-id="${data.id}">Delete</button>
                        </div>
                    </div>
                `;
                gallery.appendChild(imageCard);

                // Close modal
                const modal = bootstrap.Modal.getInstance(document.getElementById('addImageModal'));
                modal.hide();

                // Re-attach delete event listeners
                attachDeleteListeners();
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Error adding image');
            });
        });

        // Delete Image Function
        function attachDeleteListeners() {
            document.querySelectorAll('.delete-image-btn').forEach(button => {
                button.addEventListener('click', function(e) {
                    e.preventDefault();

                    if (!confirm('Are you sure you want to delete this image?')) {
                        return;
                    }

                    const imageId = this.getAttribute('data-image-id');

                    const formData = new FormData();
                    formData.append('imageId', imageId);

                    fetch('/Manage/Product/DeleteImage', {
                        method: 'POST',
                        body: formData
                    })
                    .then(response => {
                        if (response.ok) {
                            // Remove the image card
                            const card = document.querySelector(`[data-image-id="${imageId}"]`);
                            card.remove();

                            // Show empty message if no images left
                            const gallery = document.getElementById('imageGallery');
                            if (gallery.children.length === 0) {
                                gallery.innerHTML = '<div class="alert alert-info">No images found. Click "Add Image" to upload product images.</div>';
                            }
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        alert('Error deleting image');
                    });
                });
            });
        }

        // Attach delete listeners on page load
        attachDeleteListeners();
    </script>
}
