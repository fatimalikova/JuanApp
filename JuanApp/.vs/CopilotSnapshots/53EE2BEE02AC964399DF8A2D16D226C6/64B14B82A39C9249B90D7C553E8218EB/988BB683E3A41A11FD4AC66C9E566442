using JuanApp.Data;
using JuanApp.Models;
using JuanApp.Extentions;
using Microsoft.AspNetCore.Mvc;
using Microsoft.EntityFrameworkCore;

namespace JuanApp.Areas.Manage.Controllers
{
    public class BlogController : Controller
    {
        private readonly JuanDbContext _context;

        public BlogController(JuanDbContext context)
        {
            _context = context;
        }

        [Area("Manage")]
        public async Task<IActionResult> Index()
        {
            var blogs = await _context.Blogs.ToListAsync();
            return View(blogs);
        }

        [Area("Manage")]
        [HttpGet]
        public async Task<IActionResult> GetBlog(Guid id)
        {
            var blog = await _context.Blogs.FirstOrDefaultAsync(b => b.Id == id);
            if (blog == null)
            {
                return NotFound();
            }
            return Json(new
            {
                id = blog.Id,
                title = blog.Title,
                author = blog.Author,
                content = blog.Content,
                mainImageUrl = blog.MainImageUrl,
                publishedDate = blog.PublishedDate
            });
        }

        [Area("Manage")]
        public IActionResult Create()
        {
            return View();
        }

        [Area("Manage")]
        [HttpPost]
        [ValidateAntiForgeryToken]
        public async Task<IActionResult> Create(Blog blog, IFormFile mainImageFile)
        {
            if (ModelState.IsValid)
            {
                blog.Id = Guid.NewGuid();
                blog.PublishedDate = DateTime.UtcNow;

                // Handle file upload
                if (mainImageFile != null && mainImageFile.Length > 0)
                {
                    var uploadPath = Path.Combine(Directory.GetCurrentDirectory(), "wwwroot", "assets", "img", "blog");

                    // Create directory if it doesn't exist
                    if (!Directory.Exists(uploadPath))
                    {
                        Directory.CreateDirectory(uploadPath);
                    }

                    var fileName = FileManager.SaveFile(mainImageFile, uploadPath);
                    blog.MainImageUrl = fileName;
                }

                _context.Add(blog);
                await _context.SaveChangesAsync();
                return RedirectToAction(nameof(Index));
            }
            return View(blog);
        }

        [Area("Manage")]
        public async Task<IActionResult> Edit(Guid id)
        {
            var blog = await _context.Blogs.FirstOrDefaultAsync(b => b.Id == id);
            if (blog == null)
            {
                return NotFound();
            }
            return View(blog);
        }

        [Area("Manage")]
        [HttpPost]
        [ValidateAntiForgeryToken]
        public async Task<IActionResult> Edit(Guid id, Blog blog, IFormFile mainImageFile, string currentMainImageUrl)
        {
            if (id != blog.Id)
            {
                return NotFound();
            }

            // Get the existing blog to preserve relationships
            var existingBlog = await _context.Blogs.FirstOrDefaultAsync(b => b.Id == id);
            if (existingBlog == null)
            {
                return NotFound();
            }

            // Remove MainImageUrl from ModelState validation since we handle it separately
            ModelState.Remove("MainImageUrl");

            if (ModelState.IsValid)
            {
                try
                {
                    var uploadPath = Path.Combine(Directory.GetCurrentDirectory(), "wwwroot", "assets", "img", "blog");

                    // Create directory if it doesn't exist
                    if (!Directory.Exists(uploadPath))
                    {
                        Directory.CreateDirectory(uploadPath);
                    }

                    // Handle file upload
                    if (mainImageFile != null && mainImageFile.Length > 0)
                    {
                        // Delete old image if exists
                        if (!string.IsNullOrEmpty(existingBlog.MainImageUrl))
                        {
                            FileManager.DeleteFile(existingBlog.MainImageUrl, uploadPath);
                        }

                        // Save new image
                        var fileName = FileManager.SaveFile(mainImageFile, uploadPath);
                        existingBlog.MainImageUrl = fileName;
                    }
                    else if (!string.IsNullOrEmpty(currentMainImageUrl))
                    {
                        // Keep existing image if no new file uploaded
                        existingBlog.MainImageUrl = currentMainImageUrl;
                    }

                    // Update the blog properties
                    existingBlog.Title = blog.Title;
                    existingBlog.Author = blog.Author;
                    existingBlog.Content = blog.Content;
                    existingBlog.PublishedDate = blog.PublishedDate;

                    _context.Update(existingBlog);
                    await _context.SaveChangesAsync();
                    return RedirectToAction(nameof(Index));
                }
                catch (DbUpdateConcurrencyException)
                {
                    if (!BlogExists(blog.Id))
                    {
                        return NotFound();
                    }
                    else
                    {
                        throw;
                    }
                }
                catch (Exception ex)
                {
                    ModelState.AddModelError("", "Error updating blog: " + ex.Message);
                    return View(existingBlog);
                }
            }

            // Return with the existing blog data so form shows current values
            return View(existingBlog);
        }

        [Area("Manage")]
        public async Task<IActionResult> Delete(Guid id)
        {
            var blog = await _context.Blogs.FirstOrDefaultAsync(b => b.Id == id);
            if (blog == null)
            {
                return NotFound();
            }
            return View(blog);
        }

        [Area("Manage")]
        [HttpPost, ActionName("Delete")]
        [ValidateAntiForgeryToken]
        public async Task<IActionResult> DeleteConfirmed(Guid id)
        {
            var blog = await _context.Blogs.FindAsync(id);
            if (blog != null)
            {
                _context.Blogs.Remove(blog);
                await _context.SaveChangesAsync();
            }
            return RedirectToAction(nameof(Index));
        }

        private bool BlogExists(Guid id)
        {
            return _context.Blogs.Any(e => e.Id == id);
        }
    }
}
