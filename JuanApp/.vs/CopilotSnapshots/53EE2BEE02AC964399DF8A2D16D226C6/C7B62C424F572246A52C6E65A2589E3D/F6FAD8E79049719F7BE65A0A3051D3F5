@model List<JuanApp.Models.Blog>

@{
    ViewData["Title"] = "Manage Blogs";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h4 class="card-title">Blogs</h4>
                    <a asp-area="Manage" asp-controller="Blog" asp-action="Create" class="btn btn-primary btn-sm">Add New Blog</a>
                </div>
                <div class="card-body">
                    @if (Model != null && Model.Count > 0)
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Title</th>
                                        <th>Author</th>
                                        <th>Published Date</th>
                                        <th>Image</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var blog in Model)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@blog.Title</strong>
                                            </td>
                                            <td>@blog.Author</td>
                                            <td>@blog.PublishedDate.ToString("MMMM dd, yyyy")</td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(blog.MainImageUrl))
                                                {
                                                    <img src="~/assets/img/blog/@blog.MainImageUrl" alt="@blog.Title" style="max-width: 50px; max-height: 50px;" />
                                                }
                                                else
                                                {
                                                    <span class="text-muted">No Image</span>
                                                }
                                            </td>
                                            <td>
                                                <button type="button" class="btn btn-sm btn-secondary detail-btn" data-blog-id="@blog.Id">Detail</button>
                                                <a asp-area="Manage" asp-controller="Blog" asp-action="Edit" asp-route-id="@blog.Id" class="btn btn-sm btn-info">Edit</a>
                                                <button type="button" class="btn btn-sm btn-danger delete-btn" data-blog-id="@blog.Id">Delete</button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            No blogs found. <a asp-area="Manage" asp-controller="Blog" asp-action="Create">Create your first blog</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Detail Modal -->
<div class="modal fade" id="detailModal" tabindex="-1" aria-labelledby="detailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="detailModalLabel">Blog Detail</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="blogImage" class="mb-3"></div>
                <div class="mb-3">
                    <label class="form-label"><strong>Title:</strong></label>
                    <p id="blogTitle"></p>
                </div>
                <div class="mb-3">
                    <label class="form-label"><strong>Author:</strong></label>
                    <p id="blogAuthor"></p>
                </div>
                <div class="mb-3">
                    <label class="form-label"><strong>Published Date:</strong></label>
                    <p id="blogDate"></p>
                </div>
                <div class="mb-3">
                    <label class="form-label"><strong>Content:</strong></label>
                    <div class="border p-3 bg-light" id="blogContent" style="max-height: 300px; overflow-y: auto;"></div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" id="detailCloseBtn">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-danger">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel">Delete Blog</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-warning">
                    <strong>Warning!</strong> Are you sure you want to delete this blog? This action cannot be undone.
                </div>
                <div class="mb-3">
                    <label class="form-label"><strong>Title:</strong></label>
                    <p id="deleteTitle"></p>
                </div>
                <div class="mb-3">
                    <label class="form-label"><strong>Author:</strong></label>
                    <p id="deleteAuthor"></p>
                </div>
                <div class="mb-3">
                    <label class="form-label"><strong>Published Date:</strong></label>
                    <p id="deleteDate"></p>
                </div>
                <div class="mb-3">
                    <label class="form-label"><strong>Content Preview:</strong></label>
                    <div class="border p-3 bg-light" id="deleteContent" style="max-height: 200px; overflow-y: auto;"></div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" id="deleteCancelBtn">Cancel</button>
                <form id="deleteForm" method="post" style="display: inline;">
                    <input type="hidden" id="deleteId" name="Id" />
                    <button type="submit" class="btn btn-danger">Confirm Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Helper function to close modal
        function closeModal(modalId) {
            const modalElement = document.getElementById(modalId);
            if (modalElement) {
                const backdrop = document.querySelector('.modal-backdrop');
                if (backdrop) {
                    backdrop.remove();
                }
                modalElement.classList.remove('show');
                modalElement.style.display = 'none';
                document.body.classList.remove('modal-open');
            }
        }

        // Detail Button Click Handler
        document.querySelectorAll('.detail-btn').forEach(button => {
            button.addEventListener('click', function () {
                const blogId = this.getAttribute('data-blog-id');
                fetch(`/Manage/Blog/GetBlog/${blogId}`)
                    .then(response => response.json())
                    .then(data => {
                        document.getElementById('blogTitle').textContent = data.title;
                        document.getElementById('blogAuthor').textContent = data.author;
                        document.getElementById('blogDate').textContent = new Date(data.publishedDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
                        document.getElementById('blogContent').innerHTML = data.content;

                        const imageDiv = document.getElementById('blogImage');
                        if (data.mainImageUrl && data.mainImageUrl.trim() !== '') {
                            imageDiv.innerHTML = `<img src="/assets/img/blog/${data.mainImageUrl}" alt="${data.title}" style="max-width: 100%; height: auto;" />`;
                        } else {
                            imageDiv.innerHTML = '<span class="text-muted">No Image</span>';
                        }

                        const detailModal = new bootstrap.Modal(document.getElementById('detailModal'));
                        detailModal.show();
                    })
                    .catch(error => console.error('Error:', error));
            });
        });

        // Detail Close Button
        document.getElementById('detailCloseBtn').addEventListener('click', function() {
            closeModal('detailModal');
        });

        // Delete Button Click Handler
        document.querySelectorAll('.delete-btn').forEach(button => {
            button.addEventListener('click', function () {
                const blogId = this.getAttribute('data-blog-id');
                fetch(`/Manage/Blog/GetBlog/${blogId}`)
                    .then(response => response.json())
                    .then(data => {
                        document.getElementById('deleteId').value = data.id;
                        document.getElementById('deleteTitle').textContent = data.title;
                        document.getElementById('deleteAuthor').textContent = data.author;
                        document.getElementById('deleteDate').textContent = new Date(data.publishedDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
                        document.getElementById('deleteContent').innerHTML = data.content;

                        document.getElementById('deleteForm').action = `/Manage/Blog/Delete/${blogId}`;

                        const deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));
                        deleteModal.show();
                    })
                    .catch(error => console.error('Error:', error));
            });
        });

        // Delete Cancel Button
        document.getElementById('deleteCancelBtn').addEventListener('click', function() {
            closeModal('deleteModal');
        });
    </script>
}



