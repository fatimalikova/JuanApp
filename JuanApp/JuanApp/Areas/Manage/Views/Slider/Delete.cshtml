@model JuanApp.Models.Slider

@{
    ViewData["Title"] = "Delete Slider";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-8">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="card-title mb-0">Delete Slider</h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <strong>Warning!</strong> Are you sure you want to delete this slider? This action cannot be undone.
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Title:</strong></label>
                        <p>@Model.Title</p>
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Etiket:</strong></label>
                        <p>@Model.Etiket</p>
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Description:</strong></label>
                        <p>@Model.Description</p>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <div class="mb-3">
                            <label class="form-label"><strong>Image:</strong></label>
                            <div>
                                <img src="~/assets/img/slider/@Model.ImageUrl" alt="@Model.Title" style="max-width: 200px; height: auto;" />
                            </div>
                        </div>
                    }

                    <form asp-area="Manage" asp-controller="Slider" asp-action="Delete" method="post" style="display:inline;">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn btn-danger">Confirm Delete</button>
                    </form>
                    <a asp-area="Manage" asp-controller="Slider" asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </div>
        </div>
    </div>
</div>
