@model JuanApp.Models.Product

@{
    ViewData["Title"] = "Create Product";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h4 class="card-title">Create New Product</h4>
                </div>
                <div class="card-body">
                    <form asp-area="Manage" asp-controller="Product" asp-action="Create" method="post" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Product Name</label>
                            <input asp-for="Name" class="form-control" placeholder="Enter product name" required />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Enter product description"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Price" class="form-label">Price</label>
                                    <input asp-for="Price" class="form-control" placeholder="0.00" step="0.01" required />
                                    <span asp-validation-for="Price" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="DiscountPercentage" class="form-label">Discount %</label>
                                    <input asp-for="DiscountPercentage" class="form-control" placeholder="0" />
                                    <span asp-validation-for="DiscountPercentage" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="mainImageFile" class="form-label">Main Image</label>
                            <input type="file" id="mainImageFile" name="mainImageFile" class="form-control" accept="image/*" />
                            <small class="text-muted">PNG, JPG, GIF up to 2MB</small>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-check">
                                    <input asp-for="InStock" class="form-check-input" type="checkbox" />
                                    <label asp-for="InStock" class="form-check-label">In Stock</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-check">
                                    <input asp-for="IsNew" class="form-check-input" type="checkbox" />
                                    <label asp-for="IsNew" class="form-check-label">New Product</label>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary">Create Product</button>
                            <a asp-area="Manage" asp-controller="Product" asp-action="Index" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
