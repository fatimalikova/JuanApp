@using JuanApp.ViewModels.UserVm
@model LoginVm
<main>

<!-- login register wrapper start -->
<div class="login-register-wrapper section-padding">
    <div class="container">
        <div class="member-area-from-wrap">
            <div class="row">
                <!-- Login Content Start -->
                <div class="col-lg-6">
                    <div class="login-reg-form-wrap">
                        <h2>Sign In</h2>
                        <form asp-action="Login" asp-controller="Account" method="post">
                            <div class="single-input-item">
                                <input type="text" placeholder="Email or Username" required asp-for="UserNameOrEmail" />
                                <span asp-validation-for="UserNameOrEmail" class="text-danger"></span>
                            </div>
                            <div class="single-input-item">
                                <input type="password" placeholder="Enter your Password" required asp-for="Password" />
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>
                            <div class="single-input-item">
                                <div class="login-reg-form-meta d-flex align-items-center justify-content-between">
                                    <div class="remember-meta">
                                        <div class="custom-control custom-checkbox">
                                            <input type="checkbox" class="custom-control-input" id="rememberMe" asp-for="RememberMe">
                                            <label class="custom-control-label" for="rememberMe">Remember Me</label>
                                        </div>
                                    </div>
                                    <a href="#" class="forget-pwd">Forget Password?</a>
                                </div>
                            </div>
                            <div class="single-input-item">
                                <button class="btn btn-outlined" type="submit">Login</button>
                            </div>
                        </form>
                    </div>
                </div>
                <!-- Login Content End -->
            </div>
        </div>
    </div>
</div>
</main>
<!-- login register wrapper end -->
@section Scripts{
    <partial name="_ValidationScriptsPartial" />
}